params{
    input = "data/regions.csv"
    outdir = "results"
    chunk_size = 120
    candidates_per_chunk = 3
}

process {
    executor = 'local'
}

manifest {
    name = 'target-qc-nextflow'
    author = 'Zuheir Zaidon'
    description = 'A modular Nextflow pipeline for region chunking, candidate design scoring, and QC reporting'
    version = '0.1.0'
}

process {
    executor = 'local'
}

profiles {
    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled = true
        process.container = 'python:3.11-slim'
    }

    conda {
        conda.enabled = true
        process.conda = 'env.yml'
    }
}

//to add Docker, Conda, etc